<Page x:Class="MostyApp.ListaObiektowPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MostyApp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListaObiektowPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ewidencja Mostów i Kładek w Mieście" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Tabela do wyświetlania obiektów -->
        <DataGrid Grid.Row="1" Name="ObiektyDataGrid" AutoGenerateColumns="True" 
                  IsReadOnly="True" AlternatingRowBackground="#F2F6F8" HeadersVisibility="Column"/>
    </Grid>
</Page>
