<Page x:Class="MostyApp.PrzegladyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MostyApp"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1000"
      Title="PrzegladyPage" Background="White">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" Margin="0,0,20,0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Zarejestruj Przegląd" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                <TextBlock Text="Wybierz Obiekt:" FontWeight="Bold"/>
                <ComboBox Name="CmbObiekt" Margin="0,5,0,10" Padding="5"/>

                <TextBlock Text="Wybierz Inspektora:" FontWeight="Bold"/>
                <ComboBox Name="CmbInspektor" Margin="0,5,0,10" Padding="5"/>

                <TextBlock Text="Typ Przeglądu:" FontWeight="Bold"/>
                <ComboBox Name="CmbTypPrzegladu" Margin="0,5,0,10" Padding="5"/>

                <TextBlock Text="Data wykonania:" FontWeight="Bold"/>
                <DatePicker Name="DpDataWykonania" Margin="0,5,0,10"/>

                <TextBlock Text="Data ważności:" FontWeight="Bold"/>
                <DatePicker Name="DpDataWaznosci" Margin="0,5,0,10"/>

                <TextBlock Text="Stan techniczny (1-5):" FontWeight="Bold"/>
                <ComboBox Name="CmbStan" Margin="0,5,0,10" Padding="5">
                    <ComboBoxItem Content="1" IsSelected="True"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                </ComboBox>

                <TextBlock Text="Zatwierdzona nośność (tony):" FontWeight="Bold"/>
                <TextBox Name="TxtZatwierdzonaNosnosc" Margin="0,5,0,10" Padding="5"/>

                <TextBlock Text="Koszt rozliczeniowy (PLN):" FontWeight="Bold"/>
                <TextBox Name="TxtKoszt" Margin="0,5,0,10" Padding="5"/>

                <TextBlock Text="Uwagi z przeglądu:" FontWeight="Bold"/>
                <TextBox Name="TxtUwagi" Margin="0,5,0,15" Padding="5" Height="50" TextWrapping="Wrap"/>

                <Button Content="Zapisz Przegląd w Bazie" Name="BtnZapisz" Click="BtnZapisz_Click"
                        Background="#E67E22" Foreground="White" Height="45" FontSize="15" FontWeight="Bold" Cursor="Hand" Margin="0,0,0,20"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Historia Wykonanych Przeglądów" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <DataGrid Grid.Row="1" Name="PrzegladyDataGrid" AutoGenerateColumns="True" 
                      IsReadOnly="True" AlternatingRowBackground="#F2F6F8"/>
            <Button Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right"
        Content="Usuń zaznaczony przegląd" Name="BtnUsun" Click="BtnUsun_Click" 
        Background="#E74C3C" Foreground="White" Height="35" Width="200" 
        Margin="0,0,0,10" FontWeight="Bold" Cursor="Hand"/>
        </Grid>
    </Grid>
</Page>