<Page x:Class="MostyApp.DodajObiektPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MostyApp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DodajObiektPage" Background="White">

    <StackPanel Margin="30" Width="400" HorizontalAlignment="Left">

        <TextBlock Text="Dodaj nowy obiekt do ewidencji" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="Nazwa obiektu:" FontWeight="Bold" Margin="0,5,0,0"/>
        <TextBox Name="TxtNazwa" Margin="0,5,0,15" Padding="5" FontSize="14"/>

        <!-- Rozwijana lista (ComboBox) dla Typu Konstrukcji -->
        <TextBlock Text="Typ konstrukcji:" FontWeight="Bold"/>
        <ComboBox Name="CmbTyp" Margin="0,5,0,15" Padding="5" FontSize="14"/>

        <TextBlock Text="Opis lokalizacji:" FontWeight="Bold"/>
        <TextBox Name="TxtLokalizacja" Margin="0,5,0,15" Padding="5" FontSize="14"/>

        <!-- Wybór z warunku CHECK w bazie danych -->
        <TextBlock Text="Status eksploatacyjny:" FontWeight="Bold"/>
        <ComboBox Name="CmbStatus" Margin="0,5,0,15" Padding="5" FontSize="14">
            <ComboBoxItem Content="Otwarty" IsSelected="True"/>
            <ComboBoxItem Content="Ograniczenie tonażowe"/>
            <ComboBoxItem Content="Wyłączony z ruchu"/>
        </ComboBox>

        <TextBlock Text="Nośność ewidencyjna (w tonach):" FontWeight="Bold"/>
        <TextBox Name="TxtNosnosc" Margin="0,5,0,25" Padding="5" FontSize="14"/>

        <!-- Przycisk zapisu -->
        <Button Content="Zapisz obiekt" Name="BtnZapisz" Click="BtnZapisz_Click"
                Background="#2ECC71" Foreground="White" Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand"/>

    </StackPanel>
</Page>