<Page x:Class="MostyApp.InspektorzyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MostyApp"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="InspektorzyPage" Background="White">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Nowy Inspektor" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Imię:" FontWeight="Bold"/>
            <TextBox Name="TxtImie" Margin="0,5,0,10" Padding="5"/>

            <TextBlock Text="Nazwisko:" FontWeight="Bold"/>
            <TextBox Name="TxtNazwisko" Margin="0,5,0,10" Padding="5"/>

            <TextBlock Text="Nr uprawnień:" FontWeight="Bold"/>
            <TextBox Name="TxtUprawnienia" Margin="0,5,0,10" Padding="5"/>

            <TextBlock Text="Kategoria uprawnień:" FontWeight="Bold"/>
            <ComboBox Name="CmbKategoria" Margin="0,5,0,10" Padding="5"/>

            <TextBlock Text="Telefon:" FontWeight="Bold"/>
            <TextBox Name="TxtTelefon" Margin="0,5,0,10" Padding="5"/>

            <TextBlock Text="Email:" FontWeight="Bold"/>
            <TextBox Name="TxtEmail" Margin="0,5,0,15" Padding="5"/>

            <Button Content="Dodaj Inspektora" Name="BtnDodaj" Click="BtnDodaj_Click"
                    Background="#3498DB" Foreground="White" Height="40" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Lista Inspektorów" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
            <DataGrid Grid.Row="1" Name="InspektorzyDataGrid" AutoGenerateColumns="True" 
                      IsReadOnly="True" AlternatingRowBackground="#F2F6F8"/>
        </Grid>
    </Grid>
</Page>